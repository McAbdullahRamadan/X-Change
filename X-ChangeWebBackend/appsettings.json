{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Application.Services.Impelementation.PhotoService": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=X_ChangeEducation;"
    //"Trusted_Connection=True;TrustServerCertificate=True"
  },
  "jwtSettings": {
    "Secret": "ThisIsVerySecretKeyForJwtToken12345",
    "Issuer": "X-Change",
    "Audience": "WebSite",
    "ValidateAudience": true,
    "ValidateIssuer": true,
    "ValidateLifetime": true,
    "ValidateIssuerSigninKey": true,
    "AccessTokenExpireDate": 1,
    "RefreshTokenExpireDate": 20
  },
  "FileUpload": {
    "MaxSizeInMB": 50,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".gif", ".webp" ],
    "UploadPath": "wwwroot/uploads"
  }
}

